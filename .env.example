# ─── Supabase (Postgres) ────────────────────────────────────────────────────
SUPABASE_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=sua_senha_aqui
SUPABASE_PORT=5432

# ─── Google Cloud Platform ──────────────────────────────────────────────────
GCP_PROJECT_ID=seu-projeto-gcp
GCP_DATASET_BRONZE=bronze
GCP_DATASET_SILVER=silver
GCP_DATASET_GOLD=gold

# ─── Google Drive ───────────────────────────────────────────────────────────
# ID da pasta no Drive (está na URL: drive.google.com/drive/folders/<ID>)
GOOGLE_DRIVE_FOLDER_ID=seu_folder_id_aqui

# IMPORTANTE: O arquivo de credencial da Service Account GCP deve ser salvo em:
# secrets/gcp-sa.json
# Essa pasta está no .gitignore — NUNCA commite esse arquivo.
